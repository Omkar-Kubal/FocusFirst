<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Toki icon — 108×108dp viewport, safe zone 18–90dp on each axis.
        Center: (54, 54). Arcs open at top (gap = 60° centred on 12 o'clock).

        Arc geometry (angles measured clockwise from 3 o'clock):
          gap edges: 300° (upper-right) → 240° (upper-left), clockwise sweep = 300°
          large-arc-flag = 1, sweep-flag = 1

          outer (r=32): start (70, 26.29) → end (38, 26.29)
          inner (r=22): start (65, 34.95) → end (43, 34.95)
    -->

    <!-- Outer arc: radius 32dp, stroke 7dp, 300°, gap at top -->
    <path
        android:pathData="M 70,26.29 A 32,32 0 1,1 38,26.29"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="7"
        android:strokeLineCap="round" />

    <!-- Inner arc: radius 22dp, stroke 5dp, 300°, gap at top -->
    <path
        android:pathData="M 65,34.95 A 22,22 0 1,1 43,34.95"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round" />

    <!-- Red dot at top centre of outer arc — centre (54, 22), radius 5dp -->
    <path
        android:pathData="M 49,22 a 5,5 0 1,0 10,0 a 5,5 0 1,0 -10,0"
        android:fillColor="#E84B1A" />

</vector>
