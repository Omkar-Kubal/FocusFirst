<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Timer / Wake ──────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required on Android 14+ for specialUse foreground service type -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ── Notifications (runtime permission, Android 13+) ───────────── -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ── Network (Play Billing only) ───────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- ── SceneView / Filament requires OpenGL ES 3.0 ───────────────── -->
    <!-- required="false" avoids filtering on devices that can still run  -->
    <!-- the app without full 3D hardware acceleration                    -->
    <uses-feature
        android:glEsVersion="0x00030000"
        android:required="false" />

    <application
        android:name=".FocusFirstApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.FocusFirst"
        android:extractNativeLibs="false">

        <!-- ── Main Activity ─────────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.FocusFirst"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Timer Foreground Service ──────────────────────────────── -->
        <!--
            foregroundServiceType="specialUse" requires:
              - FOREGROUND_SERVICE_SPECIAL_USE permission (Android 14+)
              - PROPERTY_SPECIAL_USE_FGS_SUBTYPE property below
        -->
        <service
            android:name=".service.TimerForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Pomodoro focus timer — counts down user-initiated work sessions" />
        </service>

        <!-- ── Boot Receiver ─────────────────────────────────────────── -->
        <!-- Restores any active timer state after device reboot -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- ── App Widget Receiver ───────────────────────────────────── -->
        <!--
            Glance widget receiver must be exported=true so the launcher
            can send APPWIDGET_UPDATE broadcasts.
            meta-data points to res/xml/focus_first_widget_info.xml
            (create this file before building the widget feature).
        -->
        <receiver
            android:name=".widget.FocusFirstWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/focus_first_widget_info" />
        </receiver>

        <!-- ── WorkManager: disable default initializer ──────────────── -->
        <!--
            Hilt's HiltWorkerFactory must be set as the WorkManager factory.
            The default auto-initializer must be removed so WorkManager waits
            for FocusFirstApp.workManagerConfiguration (Configuration.Provider)
            instead of initializing itself with the default factory.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup.InitializationProvider"
                tools:node="remove" />
        </provider>

        <!-- ── FileProvider — planet screenshot sharing ───────────────── -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
